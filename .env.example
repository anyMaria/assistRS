# ——— Assistant RS — variables d'environnement ———
# Usage strictement personnel : pas d'authentification sur l'application.

# Base de données
# Dev local : file:local.db (par défaut)
# Prod (Turso) : libsql://<nom>-<org>.turso.io + token
DATABASE_URL=file:local.db
# DATABASE_AUTH_TOKEN=

# IA — Google Gemini, palier gratuit (clé : aistudio.google.com) — jamais exposée au client
GEMINI_API_KEY=AIza...
# Modèle utilisé (optionnel, défaut : gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Scrapers d'inspiration (console.apify.com → Settings → API & Integrations)
APIFY_TOKEN=apify_api_...

# E-mails bilans/rituels (resend.com → API Keys)
RESEND_API_KEY=re_...

# Cron quotidien (bilan hebdo + invitation rituel + récurrences) — chaîne aléatoire,
# à mettre aussi dans les variables d'env Vercel. Vérifiée en Authorization: Bearer.
CRON_SECRET=

# Stockage privé (logos, moodboards, rapports) — vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
