# ——— Assistant RS — variables d'environnement ———

# Mot de passe unique d'accès à l'application
APP_PASSWORD=change-moi

# Secret pour signer le cookie de session (longue chaîne aléatoire)
SESSION_SECRET=change-moi-aussi-longue-chaine-aleatoire

# Base de données
# Dev local : file:local.db (par défaut)
# Prod (Turso) : libsql://<nom>-<org>.turso.io + token
DATABASE_URL=file:local.db
# DATABASE_AUTH_TOKEN=

# API Claude (génération d'idées + analyse) — jamais exposée au client
ANTHROPIC_API_KEY=sk-ant-...
# Modèle utilisé (optionnel, défaut : claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8
